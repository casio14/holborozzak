# holborozzak.hu — Apache beállítások
#
# Egyedi 404 oldal. A holborozzak.hu gyökerén ez a helyes út (/404.php).
ErrorDocument 404 /404.php

# Szép esemény-URL: /esemeny/<slug> → esemeny.php?slug=<slug>
# Relatív minta (nincs RewriteBase), a domain gyökerén szolgálódik.
RewriteEngine On
RewriteRule ^esemeny/([a-z0-9-]+)/?$ esemeny.php?slug=$1 [L,QSA]
