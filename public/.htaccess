# holborozzak.hu — Apache beállítások
#
# Egyedi 404 oldal. A holborozzak.hu gyökerén ez a helyes út (/404.php).
ErrorDocument 404 /404.php

RewriteEngine On

# Kanonikus host: www → nem-www (301). Enélkül a www és a nem-www külön indexelődne
# (duplikált tartalom, megosztott rangsor-jelzés). A http→https-t a Rackhost proxy
# már kikényszeríti, ezért itt csak a hostot egységesítjük.
RewriteCond %{HTTP_HOST} ^www\.holborozzak\.hu$ [NC]
RewriteRule ^(.*)$ https://holborozzak.hu/$1 [R=301,L]

# Tiszta (kiterjesztés nélküli) URL-ek a tartalmi oldalakhoz.
# 1) A régi /oldal.php címet 301-gyel a kiterjesztés nélküli /oldal-ra irányítjuk,
#    hogy ne legyen duplikált tartalom és a régi linkek is a szép URL-re jöjjenek.
#    Csak GET-re fut (űrlap-POST-ot nem törünk el); a query stringet megőrzi.
RewriteCond %{REQUEST_METHOD} =GET
RewriteCond %{THE_REQUEST} \s/+(esemenyek|naptar|terkep|borvidekek|esemeny-bekuldes|impresszum|aszf|adatvedelem)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Szép esemény-URL: /esemeny/<slug> → esemeny.php?slug=<slug>
# Relatív minta (nincs RewriteBase), a domain gyökerén szolgálódik.
RewriteRule ^esemeny/([a-z0-9-]+)/?$ esemeny.php?slug=$1 [L,QSA]

# Szép borvidék-URL: /borvidek/<slug> → borvidek.php?slug=<slug>
RewriteRule ^borvidek/([a-z0-9-]+)/?$ borvidek.php?slug=$1 [L,QSA]

# A dinamikus sitemap a szabványos /sitemap.xml címen is elérhető (a Google Search
# Console és a legtöbb eszköz ezt várja) — belül a sitemap.php szolgálja ki.
RewriteRule ^sitemap\.xml$ sitemap.php [L]

# 2) Belül a kiterjesztés nélküli /oldal kérést a megfelelő /oldal.php fájl szolgálja ki.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(esemenyek|naptar|terkep|borvidekek|esemeny-bekuldes|impresszum|aszf|adatvedelem)/?$ $1.php [L,QSA]

# Statikus assetek böngésző-gyorsítótárazása (gyorsabb ismétléses betöltés → jobb
# Core Web Vitals). A CSS/JS ?v=<filemtime> cache-buster miatt biztonságos a hosszú
# lejárat. <IfModule> véd: ha a modul nincs betöltve, a blokk figyelmen kívül marad.
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/x-icon "access plus 30 days"
</IfModule>
